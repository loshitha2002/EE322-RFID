{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build AVR ASM sim (make)",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\mingw32-make.exe",
      "options": {
        "cwd": "${workspaceFolder}\\asm_sim",
        "env": {
          "Path": "${env:Path};C:\\msys64\\ucrt64\\bin"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Clean AVR ASM sim (make clean)",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\mingw32-make.exe",
      "args": [
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\asm_sim",
        "env": {
          "Path": "${env:Path};C:\\msys64\\ucrt64\\bin"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Flash TwoFactorLock (assemble + upload, COM4)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\flash_twofactorlock.ps1",
        "-Port",
        "COM4",
        "-Mode",
        "bootloader",
        "-Baud",
        "115200"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "Path": "${env:Path};C:\\msys64\\ucrt64\\bin"
        }
      },
      "problemMatcher": []
    }
  ]
}
